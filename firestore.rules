rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions & Validation Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation for User Entity
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && (data.role == "citizen" || data.role == "authority" || data.role == "admin")
        && data.createdAt is timestamp;
    }

    // Validation for Case Entity
    function isValidCase(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 5000
        && (data.status == "reported" || data.status == "analyzed" || data.status == "verifying" || data.status == "dispatched" || data.status == "in_progress" || data.status == "resolved" || data.status == "closed")
        && (data.priority == "low" || data.priority == "medium" || data.priority == "high" || data.priority == "critical")
        && data.reporterId is string && data.reporterId.size() <= 128
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) 
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]); // Block modifying role on self
      allow delete: if false;
    }

    match /cases/{caseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // We let anyone read cases for community transparency, but they are read-only
      allow create: if isSignedIn() && isValidCase(request.resource.data) 
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && isValidCase(request.resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.reporterId == resource.data.reporterId
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          // Citizens can update titles or details before in_progress, but can't touch statuses
          (request.auth.uid == resource.data.reporterId && (resource.data.status == "reported" || resource.data.status == "analyzed") && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["status", "priority", "assignedWard"])) ||
          // Authorities can update anything (assign wards, change statuses, etc.)
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["authority", "admin"])
        );
      allow delete: if false;
    }
  }
}
